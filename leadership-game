/* ====== 游戏状态 ====== */
let idx=0, lead=50, team=50, morale=50, quotes=[], answered=false;
const MAX=100;

function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}

function startGame(){
  idx=0; lead=50; team=50; morale=50; quotes=[]; answered=false;
  showScreen('game'); renderCard();
}
function restart(){ startGame(); }

function clamp(v){return Math.max(0,Math.min(MAX,v));}

function renderCard(){
  answered=false;
  document.getElementById('progPill').textContent = `第 ${idx+1} / ${SCEN.length} 关`;
  const s=SCEN[idx];
  const tagCls = s.ch==='lead'?'t-lead':(s.ch==='auth'?'t-auth':'t-mot');
  let html=`<div class="card-head"><span class="tag ${tagCls}">${s.tag}</span><span class="qcount">${s.title}</span></div>`;
  html+=`<div class="situation"><b>情景：</b>${s.sit}</div>`;
  html+=`<div class="question">${s.q}</div>`;
  html+=`<div class="options" id="opts">`;
  s.opts.forEach((o,i)=>{
    html+=`<button class="opt" onclick="choose(${i})"><span class="num">${String.fromCharCode(65+i)}</span><span>${o.t}</span></button>`;
  });
  html+=`</div><div class="feedback" id="fb"></div>`;
  document.getElementById('cardBox').innerHTML=html;
  renderMeters();
  try{ window.scrollTo({top:0, behavior:'smooth'}); }catch(e){ window.scrollTo(0,0); }
}

function choose(i){
  if(answered) return; answered=true;
  const s=SCEN[idx]; const o=s.opts[i];
  const fb=document.getElementById('fb');
  let cls='fb-good', title='✓ 最佳选择';
  if(o.v==='wrong'){cls='fb-warn';title='△ 有待改进';}
  if(o.v==='bad'){cls='fb-bad';title='✕ 需警惕';}
  if(o.v==='best'){cls='fb-good';title='✓ 最佳选择';}
  // apply deltas
  lead=clamp(lead+o.d.lead); team=clamp(team+o.d.team); morale=clamp(morale+o.d.morale);
  let quoteHtml='';
  if(o.v==='best' && o.quote){ quotes.push(o.quote); quoteHtml=`<div class="quote"><span class="badge">★ 箴言卡 +1</span><div class="q">“${o.quote.split('。——')[0]}”</div><div class="src">—— ${o.quote.split('。——')[1]||'领导力箴言'}</div></div>`; }
  let kpi=`领导力值 ${o.d.lead>=0?'+':''}${o.d.lead} · 团队合力 ${o.d.team>=0?'+':''}${o.d.team} · 追随者士气 ${o.d.morale>=0?'+':''}${o.d.morale}`;
  fb.className='feedback show '+cls;
  fb.innerHTML=`<div class="fb-title">${title}</div><div class="fb-body">${o.fb}</div>${quoteHtml}<div class="fb-kpi">${kpi}</div>`;
  // mark options
  const optsEl=document.getElementById('opts').children;
  for(let k=0;k<optsEl.length;k++){
    optsEl[k].classList.add('locked');
    if(k===i){ optsEl[k].classList.add(o.v==='best'?'correct':(o.v==='bad'?'wrong':'wrong')); }
    else optsEl[k].classList.add('dim');
  }
  renderMeters();
  // next button
  const next=document.createElement('button');
  next.type='button';
  next.className='btn btn-primary'; next.style.marginTop='16px'; next.style.width='100%';
  next.textContent = idx+1<SCEN.length ? '下一张 ▶' : '查看修炼报告 🏁';
  next.onclick = ()=>{ idx++; idx<SCEN.length?renderCard():endGame(); };
  fb.appendChild(next);
  try{ fb.scrollIntoView({behavior:'smooth', block:'nearest'}); }catch(e){}
}

function renderMeters(){
  const data=[['领导力值',lead,'var(--navy)'],['团队合力',team,'var(--teal)'],['追随者士气',morale,'var(--warn)']];
  let html='';
  data.forEach(d=>{
    html+=`<div class="meter"><div class="lab">${d[0]}</div><div class="val">${d[1]}</div><div class="bar"><i style="width:${d[1]}%;background:${d[2]}"></i></div></div>`;
  });
  document.getElementById('meters').innerHTML=html;
}

function endGame(){
  showScreen('end');
  const avg=(lead+team+morale)/3;
  let level, lvDesc;
  if(avg>=85){level='尊重';lvDesc='员工因你的人格魅力与风范而心甘情愿追随——领导者的最高境界。';}
  else if(avg>=72){level='复制';lvDesc='员工因你为他所付出的努力而拥戴你，你能复制出更多领导者。';}
  else if(avg>=60){level='结果';lvDesc='员工因你为企业付出的努力而拥戴你，用结果说话。';}
  else if(avg>=45){level='人际关系';lvDesc='员工因与你的融洽关系而拥戴你，关系基础已建立。';}
  else {level='权力';lvDesc='员工因权威而服从你。要走向真正的影响力，还需修炼。';}

  const dims=[
    ['以身作则 / 共启愿景',(lead+team)/2],
    ['授权与猴子管理',team],
    ['激励与赋能',morale],
    ['决策与担当',lead]
  ];
  let dimHtml='';
  dims.forEach(d=>{
    const pct=Math.round(d[1]);
    dimHtml+=`<div class="dim"><b>${d[0]}</b><div class="d">得分 ${pct} / 100</div><div class="bar"><i style="width:${pct}%;background:var(--gold)"></i></div></div>`;
  });

  let collHtml='';
  if(quotes.length){
    quotes.forEach((q,i)=>{
      const parts=q.split('。——'); const txt=parts[0]; const src=parts[1]||'领导力箴言';
      collHtml+=`<div class="qcard"><span class="n">箴言 ${i+1}</span>“${txt}”<div style="text-align:right;color:var(--gold);font-weight:700;font-size:11px;margin-top:6px;font-style:normal">—— ${src}</div></div>`;
    });
  } else { collHtml='<p style="color:var(--muted);font-size:13px">本局未收集到箴言卡，多尝试最佳选项即可解锁。</p>'; }

  document.getElementById('reportBox').innerHTML=`
    <h2>🏁 领导力修炼报告</h2>
    <div class="level-badge">你的境界：${level}</div>
    <p style="color:#3a3a3a;font-size:14.5px">${lvDesc}</p>
    <div class="dim-grid">${dimHtml}</div>
    <div class="summary"><b>综合评分：</b>${Math.round(avg)} / 100 ｜ <b>箴言卡收集：</b>${quotes.length} / ${SCEN.length}
    <br><b>建议：</b>${avg>=72?'你已具备领导者的核心素养，可在复杂判断与责任承担上继续精进。':(avg>=45?'夯实授权与激励的基本功，把"猴子"留在下属背上，多用正强化。':'从"安排活儿"转向"承担后果"，先练好授权流程与以身作则。')}</div>
    <div class="coll"><h3>★ 你收集的「领导箴言卡」</h3><div class="coll-grid">${collHtml}</div></div>
    <p style="font-size:12.5px;color:var(--muted);margin-top:14px;text-align:center">微信里点「分享结果」→ 右上角发送给同事一起修炼</p>
  `;
  try{ window.scrollTo({top:0, behavior:'smooth'}); }catch(e){ window.scrollTo(0,0); }
}

function showRules(){ showScreen('rules'); }
// alias for buttons: show('start') -> showScreen('start')
function show(id){ showScreen(id); }
